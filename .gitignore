# Claude Marketplace .gitignore

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Environment and secrets
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json
credentials.json

# MCP Server dependencies
node_modules/
.pnpm-store/
yarn.lock
pnpm-lock.yaml

# Python MCP Servers
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.pytest_cache/
*.egg-info/
dist/
build/

# Go MCP Servers
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
vendor/

# Logs and temporary files
*.log
*.tmp
*.temp
logs/
tmp/
temp/

# Testing and coverage
coverage/
.nyc_output/
*.cover
.coverage
.coverage.*
htmlcov/

# Build artifacts
dist/
build/
out/

# Local testing and development
test-output/
.local/
local/
*.local.*
experiments/

# Backup files
*.bak
*.backup
*~

# Compiled binaries from hooks
hooks/**/*.o
hooks/**/*.a

# Package manager locks (optional - uncomment if you want to ignore)
# package-lock.json

# Claude Code local state (if any)
.claude-local/
.claude-cache/
.tmp/
.context/
!.claude/
.claude/settings.local.json
.cursor/
.codex
.codex/tools/k8s-controller-analyzer/k8s-controller-analyzer
tools/k8s-controller-analyzer/mcp
